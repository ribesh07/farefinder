# Database URL
# For production/serverless, keep connection_limit low (e.g. 5) to avoid pool exhaustion.
# Use PgBouncer or a managed pooler when running multiple Next.js workers.
# Example: postgresql://user:password@localhost:5432/farefinder?connection_limit=5&pool_timeout=10
DATABASE_URL="postgresql://user:password@localhost:5432/farefinder?connection_limit=5&pool_timeout=10"

# JWT Secret Key
JWT_SECRET="your-secret-key-here"
